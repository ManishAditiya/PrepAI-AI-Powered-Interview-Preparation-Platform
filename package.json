{
  "name": "prepai",
  "version": "1.0.0",
  "description": "AI-Powered Interview Preparation Platform",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspaces",
    "start": "npm start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "main": ".eslintrc.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ManishAditiya/PrepAI-AI-Powered-Interview-Preparation-Platform.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ManishAditiya/PrepAI-AI-Powered-Interview-Preparation-Platform/issues"
  },
  "homepage": "https://github.com/ManishAditiya/PrepAI-AI-Powered-Interview-Preparation-Platform#readme",
  "dependencies": {
    "axios": "^1.18.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.14"
  }
}
